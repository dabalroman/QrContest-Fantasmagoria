rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Photo-proof pins (#19) — the ONLY place a client may write directly to Firebase infra. Owner
    // only, <10MB, image/* content type. Overwrite is ALLOWED (no `resource == null`): create-only has
    // an orphan trap where an upload whose submitPhotoHandle call was dropped could never be replaced,
    // so retries/orphans self-heal by overwriting the single path. One object per (player, pin), so
    // bulk upload is impossible. Admins read photos via server-built download-token URLs, NOT a rule.
    match /users/{uid}/photos/{pinUid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Everything else stays denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
