/* eslint-disable max-len */
import { Timestamp } from 'firebase-admin/firestore';
import { Pin, PinType } from '../types/pin';

// Dev fixture. The real pins — real codes, real coords, real map ids — are authored in #16.
//
// Shaped for TESTABILITY, not flavour: the location achievements (#37) score a whole map or a whole
// building, so this gives every one of the 9 maps the SAME small number of collectible pins. Four is
// deliberate — enough that a floor badge is a real errand, few enough to walk in a minute.
//
// Codes are predictable, so they can be typed straight into /collect without reading this file:
//   <TAG>000000<n>  →  DWO0000001, MPA0000003, LP20000004, …
// Every generated pin carries a question, so the answer ladder (Puchacz @30 correct) is reachable
// too, and 36 pins x ~22 pts plus question points clears 1000 (Legenda) on their own.
//
// Resulting achievement targets, all of them actually reachable:
//   map:dwor 6, map:mok-pietro-1 5, every other map:* 4
//   group:mok 21, group:2lo 12, group:dwor 5
const MAPS: { mapId: string, tag: string, group: string }[] = [
    { mapId: 'dwor', tag: 'DWO', group: 'dwor' },
    { mapId: 'mok-piwnica', tag: 'MPI', group: 'mok' },
    { mapId: 'mok-parter', tag: 'MPA', group: 'mok' },
    { mapId: 'mok-pietro-1', tag: 'MP1', group: 'mok' },
    { mapId: 'mok-pietro-1-5', tag: 'MPH', group: 'mok' },
    { mapId: 'mok-pietro-2', tag: 'MP2', group: 'mok' },
    { mapId: '2lo-parter', tag: 'LPA', group: '2lo' },
    { mapId: '2lo-pietro-1', tag: 'LP1', group: '2lo' },
    { mapId: '2lo-pietro-2', tag: 'LP2', group: '2lo' }
];

const PINS_PER_MAP = 4;
const PIN_VALUES = [30, 25, 20, 15];

const mapPins: Pin[] = MAPS.flatMap((map, mapIndex) =>
    Array.from({ length: PINS_PER_MAP }, (_unused, slot): Pin => {
        const n = slot + 1;

        return {
            uid: `${map.mapId}-${n}`,
            name: `${map.tag} ${n}`,
            description: 'Testowa pinezka do przechodzenia osiągnięć lokalizacyjnych. Prawdziwą treść dostarcza #16.',
            clue: '',
            type: PinType.CODE,
            groups: [map.group],
            mapId: map.mapId,
            coords: { x: 150 + slot * 200, y: 150 + (mapIndex % 4) * 160 },
            hintRadius: null,
            value: PIN_VALUES[slot % PIN_VALUES.length],
            withQuestion: true,
            availableFrom: null,
            availableTo: null,
            isActive: true,
            code: `${map.tag}000000${n}`,
            collectedBy: {}
        };
    })
);

// Branch coverage for the non-`code` paths. Deliberately chosen NOT to make any badge unobtainable:
//   - riddle and visit ARE collectible, so they simply raise their own map's target by one.
//   - feedback and the inactive pin are EXCLUDED from every target — feedback because
//     collectPinHandle refuses it (COLLECTIBLE_PIN_TYPES), inactive because it is not active.
//     Counting either would leave its map's badge permanently one pin short of reachable.
const branchPins: Pin[] = [
    {
        uid: 'zagadka-alchemika',
        name: 'Zagadka Alchemika',
        description: 'Na stole bulgocze coś zielonego. Alchemik zniknął, zostawiając tylko notatkę i mocno nadpalony sufit.',
        clue: 'Szklane naczynie z długą szyjką, w którym destyluje się esencje. Siedem liter, zaczyna się na "a".',
        type: PinType.RIDDLE,
        groups: ['mok', 'rzemioslo'],
        mapId: 'mok-pietro-1',
        coords: { x: 260, y: 620 },
        hintRadius: null,
        value: 15,
        withQuestion: false,
        availableFrom: null,
        availableTo: null,
        isActive: true,
        code: 'alembik',
        collectedBy: {}
    },
    {
        uid: 'stragan-zielarki',
        name: 'Stragan Zielarki',
        description: 'Zioła na sen, zioła na odwagę, zioła na „nie pytaj". Zielarka nie przyjmuje zwrotów.',
        clue: '',
        type: PinType.VISIT,
        groups: ['dwor', 'targowisko'],
        mapId: 'dwor',
        coords: { x: 540, y: 620 },
        hintRadius: null,
        value: 5,
        withQuestion: false,
        availableFrom: null,
        availableTo: null,
        isActive: true,
        code: null,
        collectedBy: {}
    },
    {
        uid: 'sala-wielka',
        name: 'Sala Wielka',
        description: 'Największa sala prelekcyjna. Powiedz nam, czego tu wysłuchałeś i czy było warto.',
        clue: '',
        type: PinType.FEEDBACK,
        groups: ['2lo', 'prelekcje'],
        mapId: '2lo-parter',
        coords: { x: 200, y: 620 },
        hintRadius: null,
        value: 5,
        withQuestion: false,
        availableFrom: null,
        availableTo: null,
        isActive: true,
        code: null,
        collectedBy: {}
    },
    {
        uid: 'zapomniana-krypta',
        name: 'Zapomniana Krypta',
        description: 'Zejście zasypano lata temu. Ktoś jednak wciąż zostawia przy wejściu świeże kwiaty.',
        clue: '',
        type: PinType.CODE,
        groups: ['2lo', 'bestiariusz'],
        mapId: '2lo-pietro-2',
        coords: { x: 320, y: 620 },
        hintRadius: null,
        value: 25,
        withQuestion: false,
        availableFrom: null,
        availableTo: null,
        // Deliberately inactive — exercises the 'pin is not active' branch.
        isActive: false,
        code: 'KRYPTA0001',
        collectedBy: {}
    },
    {
        uid: 'pomnik-zalozyciela',
        name: 'Pomnik Założyciela',
        description: 'Stoi tu od zawsze i patrzy surowo. Zrób sobie z nim zdjęcie na dowód, że tu dotarłeś/aś.',
        clue: '',
        // The photo-proof branch (#19). Like feedback, `photo` is EXCLUDED from every achievement target
        // (COLLECTIBLE_PIN_TYPES), so it can sit in any scope without making a badge unobtainable. The
        // whole feature is inert until at least one photo pin is seeded — the kill-switch is "seed none".
        type: PinType.PHOTO,
        groups: ['dwor', 'targowisko'],
        mapId: 'dwor',
        coords: { x: 420, y: 500 },
        hintRadius: null,
        value: 20,
        withQuestion: false,
        availableFrom: null,
        availableTo: null,
        isActive: true,
        code: null,
        collectedBy: {}
    },
    {
        uid: 'nocny-patrol',
        name: 'Nocny Patrol',
        description: 'Straż obchodzi mury tylko po zmroku. Za dnia nie ma tu nikogo — poza wroną, która niczego nie podpisze.',
        clue: '',
        type: PinType.CODE,
        groups: ['nocne'],
        mapId: 'dwor',
        coords: { x: 610, y: 700 },
        hintRadius: 150,
        value: 10,
        withQuestion: false,
        // Carries an availability window so #17's UI has something to render, but the window is
        // deliberately WIDE OPEN in dev.
        // ⚠️ A window is NOT excluded from an achievement target (that is by design — the badge tracks
        // the eventual full set, not what happens to be live). So a pin whose window is SHUT silently
        // makes its map's badge unobtainable for the duration. Keep dev windows open, and cover the
        // shut-window branches in the e2e suite instead (fixtures.mjs PIN_FUTURE / PIN_UNAVAILABLE).
        availableFrom: Timestamp.fromDate(new Date('2026-07-01T00:00:00+02:00')),
        availableTo: Timestamp.fromDate(new Date('2026-08-31T23:59:59+02:00')),
        isActive: true,
        code: 'NOCPATROL1',
        collectedBy: {}
    }
];

const pinsSeed: Pin[] = [...mapPins, ...branchPins];

export default pinsSeed;
