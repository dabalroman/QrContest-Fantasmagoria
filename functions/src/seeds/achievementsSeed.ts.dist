import { Achievement } from '../types/achievement';

// TEMPLATE - copy to achievementsSeed.ts and author the real definitions there. The real file is
// gitignored and ships in seeds.zip: the thresholds, bonuses and the full badge list are a spoiler,
// and this repo is public.
//
// These are DATA: `type` selects one of the engine's pure counter accessors
// (functions/src/achievements/typePredicates.ts) and `target` is the threshold, so adding an
// achievement of an EXISTING type means adding an entry here - no engine change, no redeploy. Adding
// a new TYPE is a code change, and the AchievementType union makes that compile-enforced.
//
// `icon` is a string KEY the client maps to a FontAwesome icon - never an IconDefinition.
//
// `order` is the /achievements display sort key (lower first) - author it in blocks of 100 per
// category with gaps so a new badge slots in without a renumber.
//
// One example per type follows; the real file carries the full ladder.
const achievementsSeed: Achievement[] = [
    // Counter is user.score - and bonuses fold back into score, so these can cascade.
    {
        uid: 'przyklad-punkty',
        name: 'Nazwa odznaki',
        description: 'Zdobądź 100 punktów.',
        icon: 'medal',
        group: 'punkty',
        type: 'points',
        target: 100,
        bonus: 10,
        order: 100
    },
    // Counter is user.amountOfCorrectAnswers - wrong answers do not count. Cap the target against the
    // number of pins that actually draw a question (withQuestion, non-feedback), or it is unreachable.
    {
        uid: 'przyklad-pytania',
        name: 'Nazwa odznaki',
        description: 'Odpowiedz poprawnie na 10 pytań.',
        icon: 'owl',
        group: 'pytania',
        type: 'correctAnswers',
        target: 10,
        bonus: 10,
        order: 200
    },
    // Location badge. `scope` is a pinScopeKeys.ts key - `map:<mapId>` or `group:<groupUid>`.
    // `target` here is DERIVED, not authored: recomputeAchievementTargets overwrites it on every pin
    // create/edit/delete/re-seed with the count of ACTIVE pins in that scope, so the 0 below is only
    // ever live for the instant between this seed write and the recompute that follows it. Authoring
    // a value is pointless. Note that a `photo` pin in the scope means the badge cannot complete until
    // an admin approves that photo - keep them out of any scope that must stay self-serve.
    //
    // `scope` may also be `type:<pinType>` (e.g. `type:code`) for a "collect every pin of this kind"
    // badge - same DERIVED-target machinery, no manual grouping needed since pin type is intrinsic.
    {
        uid: 'przyklad-lokalizacja',
        name: 'Nazwa odznaki',
        description: 'Odwiedź wszystkie pinezki w tej lokalizacji.',
        icon: 'map-pin',
        group: 'lokalizacja',
        type: 'pinsInScope',
        scope: 'map:dwor',
        target: 0,
        bonus: 15,
        order: 300
    }
    // ...
];

export default achievementsSeed;
