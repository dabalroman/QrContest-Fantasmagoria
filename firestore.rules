rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {
        function isUserAdmin() {
            return request.auth.uid != null
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
        }

        match /users/{userId} {
            allow read: if request.auth != null && (request.auth.uid == userId || isUserAdmin());

            allow write: if false;

            match /collectedCards/{cardId} {
                allow read: if request.auth != null
                    && request.auth.uid == userId;

                allow write: if false;
            }

            match /collectedPins/{pinId} {
                allow read: if request.auth != null
                    && request.auth.uid == userId;

                allow write: if false;
            }
        }

        match /users-usernames/{username} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        match /cards/{cardId} {
            allow read: if request.auth != null
                && isUserAdmin();

            allow write: if false;
        }

        match /pins/{pinId} {
            allow read: if request.auth != null
                && isUserAdmin();

            allow write: if false;
        }

        match /clues/{clueId} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        match /cardSets/{cardSet} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        match /ranking/{ranking} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        match /guilds/{guild} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        // Achievement definitions hold nothing secret (name, icon, type, target, bonus), so unlike
        // pins they are readable by any signed-in player - that is what lets the achievements screen
        // show ALL achievements with progress, without a callable or a per-user clone.
        match /achievements/{achievement} {
            allow read: if request.auth != null;

            allow write: if false;
        }

        // Photo-proof submissions (#19). The owner may read their OWN submissions (so the map pin sheet
        // could show pending/approved/rejected) - admins read the whole queue through the
        // getPhotoSubmissionsHandle callable. All writes go through the submit/review callables.
        match /photoSubmissions/{submissionId} {
            allow read: if request.auth != null
                && resource.data.userUid == request.auth.uid;

            allow write: if false;
        }

        // Pin group taxonomy - nothing secret (uid/name/icon), so unlike pins themselves it is
        // readable by any signed-in client. Feeds the admin pin editor's group dropdown. Mutated only
        // by the seed / Firestore console; upsertPinHandle reads it to validate a pin's groups[].
        match /pinGroups/{pinGroup} {
            allow read: if request.auth != null;

            allow write: if false;
        }
    }
}
